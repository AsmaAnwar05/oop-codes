    {
        name="You did not entered any name";
        age=0;        //default value
    }

    person(string n,int a){name=n;age=a;}    //perameterize

void show()
{
    cout<<"Name= "<<name<<endl<<"Age= "<<age<<endl;   
                                                    
}                             
};

int main()
{
    string n;
